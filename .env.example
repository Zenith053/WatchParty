# Copy to .env and fill in values
WP_PORT=3000
# PostgreSQL connection string (leave commented out for in-memory mode)
# WP_DATABASE_URL=postgresql://localhost:5432/watchparty
# Redis connection string (leave commented out for memory-only state)
# WP_REDIS_URL=redis://localhost:6379
# Optional: set to 'production' for stricter error handling
WP_NODE_ENV=development
