{
  "name": "watchparty",
  "version": "1.0.0",
  "description": "Social & Collaborative Viewing Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "jest --testEnvironment node --forceExit --coverage",
    "test:ci": "jest --testEnvironment node --forceExit --coverage --ci",
    "lint": "eslint server/ tests/",
    "lint:fix": "eslint server/ tests/ --fix",
    "format": "prettier --write server/ tests/",
    "format:check": "prettier --check server/ tests/"
  },
  "jest": {
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/index.js",
      "!server/handlers/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "coverageReporters": ["text", "text-summary", "lcov"]
  },
  "dependencies": {
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "uuidv7": "^1.0.2",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0"
  }
}
