# Copy to .env and fill in values
WP_PORT=3000
# Leave empty or comment out to use in-memory mode (no PostgreSQL needed)
# WP_DATABASE_URL=postgresql://localhost:5432/watchparty
# Leave empty or comment out to use memory-only state (no Redis needed)
# WP_REDIS_URL=redis://localhost:6379
# Optional: set to 'production' for stricter error handling
WP_NODE_ENV=development
